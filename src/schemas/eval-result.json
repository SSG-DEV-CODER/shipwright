{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvalResult",
  "description": "Adversarial evaluation result",
  "type": "object",
  "required": ["passed", "overallScore", "scores", "feedback", "failureReasons"],
  "additionalProperties": false,
  "properties": {
    "passed": {
      "type": "boolean",
      "description": "True ONLY if ALL scores are 7 or above"
    },
    "overallScore": {
      "type": "number",
      "description": "Average of all individual scores (0-10)"
    },
    "scores": {
      "type": "array",
      "description": "One entry per acceptance criterion",
      "items": {
        "type": "object",
        "required": ["criterionId", "criterion", "score", "reasoning", "specificFailures"],
        "additionalProperties": false,
        "properties": {
          "criterionId": {
            "type": "string",
            "description": "Criterion ID (e.g., ac-001)"
          },
          "criterion": {
            "type": "string",
            "description": "What was being evaluated"
          },
          "score": {
            "type": "number",
            "description": "Score 1-10. 7+ means acceptable."
          },
          "reasoning": {
            "type": "string",
            "description": "Why this score"
          },
          "specificFailures": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Specific failures found"
          }
        }
      }
    },
    "feedback": {
      "type": "string",
      "description": "Detailed feedback for the Generator"
    },
    "failureReasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Top-level failure reasons"
    }
  }
}
